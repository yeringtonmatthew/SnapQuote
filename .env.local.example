# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
# SNAPQUOTE_ANTHROPIC_KEY=  # Optional: override AI key for SnapQuote-specific usage

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PLATFORM_FEE_PERCENT=0.5

# Twilio
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=your_twilio_phone_number
# TWILIO_MESSAGING_SERVICE_SID=  # Optional: use Messaging Service instead of phone number (required for A2P 10DLC)

# Email (Resend)
# RESEND_API_KEY=  # Required for sending quote emails
# RESEND_FROM_EMAIL=SnapQuote <quotes@snapquote.dev>  # Optional: custom sender address

# Cron Jobs
# CRON_SECRET=  # Secret for authenticating cron job requests

# Google Places
# GOOGLE_PLACES_API_KEY=  # For address autocomplete

# Sentry (error tracking)
# SENTRY_ORG=  # Sentry organization slug
# SENTRY_PROJECT=  # Sentry project name
# NEXT_PUBLIC_SENTRY_DSN=  # Sentry client-side DSN

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
